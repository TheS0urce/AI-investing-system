AI_API_KEY=replace_with_local_generated_key
AI_RATE_LIMIT_PER_MINUTE=60
AI_API_HOST=127.0.0.1
AI_API_PORT=8001

# Paper broker integration.
BROKER_PROVIDER=alpaca
BROKER_MODE=paper
BROKER_LIVE_ENABLED=false
ALPACA_PAPER_API_KEY=replace_me
ALPACA_PAPER_SECRET_KEY=replace_me
ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets
AI_PAPER_PREAUTHORIZATION_PATH=state/paper_preauthorization.json

# Live trading remains disabled until BROKER_MODE=live and
# BROKER_LIVE_ENABLED=true are both set, separate live credentials are present,
# live preflight passes, and AUTHORIZE_BOUNDED_LIVE activates a 24-hour lease.
ALPACA_LIVE_API_KEY=replace_only_when_launching_live
ALPACA_LIVE_SECRET_KEY=replace_only_when_launching_live
ALPACA_LIVE_BASE_URL=https://api.alpaca.markets
AI_LIVE_EXPECTED_CAPITAL_USD=300
AI_LIVE_CAPITAL_TOLERANCE_USD=50
AI_LIVE_AUTHORIZATION_PATH=state/live_authorization.json
AI_LIVE_PROTECTIVE_EXIT_PATH=state/live_protective_exits.json
AI_LIVE_WATCH_HISTORY_PATH=logs/live_watch_history.jsonl
